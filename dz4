import random

# Списки питань і завдань (можеш додавати свої)
truths = [
    "Який твій найбільший секрет?",
    "Кого з присутніх ти вважаєш найпривабливішим?",
    "Яка найсмішніша ситуація, що трапилася з тобою на побаченні?",
    "Що ти ніколи не розповідав своїм батькам?",
    "Яка твоя найгірша звичка?",
    "Чи брехав ти комусь з присутніх?",
    "Що ти найбільше ненавидиш у собі?"
]

dares = [
    "Зроби 10 присідань і голосно крикни 'Я найкращий!'",
    "Потанцюй 20 секунд без музики",
    "Подзвони останньому контакту і скажи 'Я тебе кохаю'",
    "З'їж ложку гірчиці (якщо є)",
    "Покажи свій найсмішніший танок",
    "Поспівай пісню голосом навпаки",
    "Обійми кожного присутнього"
]


def get_choice():
    while True:
        choice = input("\nПравда (П) чи Дія (Д)? ").strip().lower()
        if choice in ['п', 'правда', 'p', 'truth']:
            return "правда"
        elif choice in ['д', 'дія', 'd', 'dare']:
            return "дія"
        else:
            print("Неправильний вибір! Введи П або Д")


print("=== ГРА ПРАВДА АБО ДІЯ ===\n")

while True:
    choice = get_choice()

    if choice == "правда":
        print("\n🎯 ПРАВДА:")
        print(random.choice(truths))
    else:
        print("\n🔥 ДІЯ:")
        print(random.choice(dares))

    again = input("\nХочеш ще раз? (y/n): ").strip().lower()
    if again != 'y':
        print("Дякую за гру! До зустрічі 👋")
        break
