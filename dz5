def corrector(string: str, width: int, symbol: str = ' ') -> str:
  
    
    Args:
        string (str): Вхідний рядок для форматування
        width (int): Загальна бажана ширина результату
        symbol (str): Символ для заповнення (за замовчуванням пробіл)
    
    Returns:
        str: Відформатований рядок
    """
    if not symbol or len(symbol) != 1:
        symbol = ' '  рядка
    
  
    if width <= len(string):
        return string
    
   
    total_padding = width - len(string)
    
 
    left_padding = total_padding // 2
    right_padding = total_padding - left_padding  # якщо непарна кількість — один символ йде праворуч
    
    # Створюємо результат
    result = symbol * left_padding + string + symbol * right_padding
    
    return result
