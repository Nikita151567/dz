import random

print("Игра: Камень, Ножницы, Бумага")
print("Напиши: камень, ножницы или бумага\n")

options = ["камень", "ножницы", "бумага"]

while True:
    player = input("Твой выбор: ").lower().strip()

    if player not in options:
        print("Пиши только: камень, ножницы или бумага!\n")
        continue

    computer = random.choice(options)

    print(f"Ты выбрал: {player}")
    print(f"Компьютер выбрал: {computer}\n")

    if player == computer:
        print("Ничья! \n")
    elif (player == "камень" and computer == "ножницы") or \
            (player == "ножницы" and computer == "бумага") or \
            (player == "бумага" and computer == "камень"):
        print("Ты выиграл!\n")
    else:
        print("Компьютер выиграл!\n")

    again = input("Играем ещё? (да/нет): ").lower().strip()
    if again != "да":
        print("Спасибо за игру! Пока")
        break
